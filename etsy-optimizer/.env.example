# Browser Configuration (for scraping and applying changes)
BROWSER_EXE=C:/Path/To/Your/Browser/browser.exe
BROWSER_USER_DATA=C:/Path/To/Your/Browser/UserData
DEBUG_PORT=9333

# Pinterest API (optional - only needed for pinterest_auth.js / pinterest_post.js)
PINTEREST_APP_ID=YOUR_PINTEREST_APP_ID
PINTEREST_APP_SECRET=YOUR_PINTEREST_APP_SECRET

# Pinterest Board (optional - for pinterest_board.js)
PINTEREST_BOARD_NAME=YOUR_BOARD_NAME
PINTEREST_BOARD_DESCRIPTION=YOUR_BOARD_DESCRIPTION
